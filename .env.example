# =============================================================================
# Lex the Computer V2 — Environment Variables
# Copy to .env and fill in required values.
# =============================================================================

# --- AI Provider Keys (at least one required) ---
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=

# --- Agent Harness ---
AGENT_HARNESS=hermes
HERMES_API_KEY=lex-local-dev

# --- Database ---
POSTGRES_PASSWORD=postgres

# --- Auth ---
SESSION_SECRET=change-me-in-production
# ALLOWED_EMAILS=

# --- Stripe (optional) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_CONNECT_CLIENT_ID=

# --- Media (optional) ---
# FAL_KEY=
# GROQ_API_KEY=
# GEMINI_API_KEY=

# --- OAuth Providers (optional) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# NOTION_CLIENT_ID=
# NOTION_CLIENT_SECRET=
# DROPBOX_CLIENT_ID=
# DROPBOX_CLIENT_SECRET=
# LINEAR_CLIENT_ID=
# LINEAR_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=

# --- Channels (optional) ---
# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=

# --- Multi-user (reserved) ---
# MULTI_USER=false
# ADMIN_EMAIL=

# --- Server ---
BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Ports (defaults shown) ---
# WEB_PORT=3000
# API_PORT=8000
# POSTGRES_PORT=5432
# REDIS_PORT=6379

# --- Caddy (production) ---
# PUBLIC_DOMAIN=localhost
# CADDY_EMAIL=

# --- OpenClaw (only for docker-compose.openclaw.yml) ---
# OPENCLAW_GATEWAY_TOKEN=dev-token
