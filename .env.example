# Lex the Computer — V2 Environment Variables
# Copy to .env and fill in values

# ── OpenClaw (required) ──────────────────────────
OPENCLAW_GATEWAY_TOKEN=           # Auto-generated on first boot if empty

# ── AI Provider (at least one required) ──────────
ANTHROPIC_API_KEY=                # For Claude (also used by Honcho deriver)
# OPENAI_API_KEY=                 # For GPT/Codex
# OPENROUTER_API_KEY=             # For OpenRouter (200+ models)

# ── Honcho Memory (optional) ────────────────────
# GEMINI_API_KEY=                 # Used by Honcho deriver for summaries

# ── Media Generation (optional) ─────────────────
# FAL_KEY=                        # fal.ai image/video generation
# GROQ_API_KEY=                   # Groq Whisper transcription

# ── Commerce (optional) ─────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_CONNECT_CLIENT_ID=

# ── Channels (configured during onboarding) ─────
# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=

# ── OAuth Integrations (optional) ───────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# NOTION_CLIENT_ID=
# NOTION_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# LINEAR_CLIENT_ID=
# LINEAR_CLIENT_SECRET=
# DROPBOX_CLIENT_ID=
# DROPBOX_CLIENT_SECRET=
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=

# ── Caddy / Domain ──────────────────────────────
# CADDY_EMAIL=admin@example.com
# PUBLIC_DOMAIN=lex.example.com
