# =============================================================================
# Lex the Computer V2 — Environment Variables
# Copy to .env and fill in required values.
# Full reference: docs/SETUP.md
# =============================================================================

# --- AI Provider Keys (at least one required) --------------------------------
# Anthropic is recommended — used by both Hermes agent and Honcho memory.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=

# --- Agent Harness -----------------------------------------------------------
# Which agent harness to use: "hermes" (default) or "openclaw".
AGENT_HARNESS=hermes
# Shared secret between the API and Hermes. Change in production.
HERMES_API_KEY=lex-local-dev

# --- Database ----------------------------------------------------------------
# PostgreSQL password. Change in production.
POSTGRES_PASSWORD=postgres

# --- Auth --------------------------------------------------------------------
# Secret for signing session cookies. Change in production.
SESSION_SECRET=change-me-in-production
# Comma-separated list of allowed login emails. Empty = allow any email.
# ALLOWED_EMAILS=

# --- Stripe Commerce (optional) ----------------------------------------------
# Stripe Connect for 0% platform-fee commerce. Get keys at stripe.com/dashboard.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_CONNECT_CLIENT_ID=

# --- Media APIs (optional) ---------------------------------------------------
# fal.ai: image/video generation (FLUX, Kling, Veo). https://fal.ai
# FAL_KEY=
# Groq: fast Whisper speech-to-text. https://groq.com
# GROQ_API_KEY=
# Gemini: used by Honcho deriver for memory summaries.
# GEMINI_API_KEY=

# --- OAuth Integrations (optional) -------------------------------------------
# Each pair enables an integration in Settings > Integrations.
# Redirect URI pattern: {BASE_URL}/api/integrations/{provider}/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# NOTION_CLIENT_ID=
# NOTION_CLIENT_SECRET=
# DROPBOX_CLIENT_ID=
# DROPBOX_CLIENT_SECRET=
# LINEAR_CLIENT_ID=
# LINEAR_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=

# --- Channels (optional) -----------------------------------------------------
# Telegram: create a bot via @BotFather, paste token here.
# TELEGRAM_BOT_TOKEN=
# Discord: create an app at discord.com/developers, paste bot token here.
# DISCORD_BOT_TOKEN=

# --- Multi-User (reserved for future) ----------------------------------------
# MULTI_USER=false
# ADMIN_EMAIL=

# --- Server -------------------------------------------------------------------
# Backend API base URL. Change to your production URL when deploying.
BASE_URL=http://localhost:8000
# API URL used by the frontend (baked into the Next.js build).
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Ports (defaults shown) --------------------------------------------------
# Override if you have port conflicts on the host.
# WEB_PORT=3000
# API_PORT=8000
# POSTGRES_PORT=5432
# REDIS_PORT=6379

# --- Caddy / HTTPS (production) ----------------------------------------------
# Set PUBLIC_DOMAIN to a real domain and Caddy auto-provisions TLS via Let's Encrypt.
# PUBLIC_DOMAIN=localhost
# CADDY_EMAIL=

# --- OpenClaw (only with docker-compose.openclaw.yml) -------------------------
# Authentication token for the OpenClaw WebSocket gateway.
# OPENCLAW_GATEWAY_TOKEN=dev-token
