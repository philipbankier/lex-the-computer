# STABILITY_API_KEY=
# REPLICATE_API_TOKEN=

# Google Maps
# GOOGLE_MAPS_API_KEY=

# Airtable
# AIRTABLE_API_KEY=

# Spotify
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=

# Microsoft (OneDrive + Outlook)
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=

# === Phase 11: Commerce & Multi-User ===
# Stripe Connect (0% platform fee commerce)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_CONNECT_CLIENT_ID=

# Multi-user container isolation
# MULTI_USER=false
# CONTAINER_IDLE_TIMEOUT=1800
# CONTAINER_CPU_LIMIT=1
# CONTAINER_MEMORY_LIMIT=2g
# CONTAINER_STORAGE_LIMIT=10g

# Admin
# ADMIN_EMAIL=admin@example.com

# Landing page (show for unauthenticated visitors)
# SHOW_LANDING=false

