# Web
NEXT_PUBLIC_APP_URL=http://localhost:3000
WEB_PORT=3000

# Core API
CORE_PORT=3001
CORE_URL=http://localhost:3001

# Auth (Better Auth)
AUTH_SECRET=change-me
AUTH_COOKIE_NAME=lex_session

# Database
POSTGRES_USER=lex
POSTGRES_PASSWORD=lexpassword
POSTGRES_DB=lex
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://lex:lexpassword@postgres:5432/lex

# Redis
REDIS_URL=redis://redis:6379

# LiteLLM
LITELLM_PORT=4000
LITELLM_URL=http://litellm:4000

# Caddy
CADDY_EMAIL=you@example.com
PUBLIC_DOMAIN=localhost

# Misc
NODE_ENV=development
MULTI_USER=false
SEED_USER_EMAIL=test@example.com
SEED_USER_PASSWORD=password123

